# OpenPoke Configuration
# Copy this file to .env and fill in your API keys

# Required: OpenRouter API key for LLM access
# Get your key from https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Required: Composio API key and Gmail auth config ID
# Get these from https://composio.dev/
COMPOSIO_API_KEY=your_composio_api_key_here
COMPOSIO_GMAIL_AUTH_CONFIG_ID=your_gmail_auth_config_id_here

# Optional: Server configuration
# OPENPOKE_HOST=0.0.0.0
# OPENPOKE_PORT=8001

# Optional: CORS configuration
# OPENPOKE_CORS_ALLOW_ORIGINS=*

# Optional: Documentation
# OPENPOKE_ENABLE_DOCS=1
# OPENPOKE_DOCS_URL=/docs

# Optional: LLM model selection (tiered by task complexity)
# Prompt caching is only active for anthropic/* models
# INTERACTION_AGENT_MODEL=anthropic/claude-sonnet-4-5
# EXECUTION_AGENT_MODEL=openai/gpt-4.1-mini
# EXECUTION_AGENT_SEARCH_MODEL=openai/gpt-4.1-mini
# SUMMARIZER_MODEL=openai/gpt-4.1-nano
# EMAIL_CLASSIFIER_MODEL=openai/gpt-4.1-nano
# Set to "false" to disable prompt caching even for Anthropic models
# ENABLE_PROMPT_CACHING=auto

# Optional: Embedding model for semantic agent roster selection (must support /embeddings via OpenRouter)
# EMBEDDING_MODEL=openai/text-embedding-3-small

# Optional: Interaction agent context window (approx tokens; drops oldest iteration pairs when exceeded)
# INTERACTION_AGENT_MAX_CONTEXT_TOKENS=80000

# Optional: Conversation summarisation thresholds
# Prod recommended: CONVERSATION_SUMMARY_THRESHOLD=100
# Prod recommended: CONVERSATION_SUMMARY_TAIL_SIZE=10
# Prod recommended: CONVERSATION_SUMMARY_CHAR_THRESHOLD=100000
CONVERSATION_SUMMARY_THRESHOLD=10
CONVERSATION_SUMMARY_TAIL_SIZE=2
CONVERSATION_SUMMARY_CHAR_THRESHOLD=20000
